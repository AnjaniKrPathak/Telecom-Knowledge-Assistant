# Template for config/webex-secrets.yml — copy this file to "webex-secrets.yml" in the same
# folder and fill in your real token. The real file is git-ignored and never committed.
#
#   cp config/webex-secrets.yml.example config/webex-secrets.yml
#
# Get a bot token from: https://developer.webex.com/my-apps -> Create a Bot

webex:
  bot-token: PASTE_YOUR_WEBEX_BOT_TOKEN_HERE
